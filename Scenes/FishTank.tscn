; ── Goldfish ──────────────────────────────────────────────────────────────────

[node name="Goldfish" type="Node3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, -0.3, 0)

; FishController drives movement; references FoodManager sibling
[node name="FishController" type="Node3D" parent="Goldfish"]
